# ───────────────────────────────────────────────────────────────────────
# PLATAFORMA GENIA — Variables de Entorno
# ───────────────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y rellena los valores.
# NUNCA subas el archivo .env real al repositorio.

# ═══════════════════════════════════════════════════════════════════════
# BACKEND (FastAPI)
# ═══════════════════════════════════════════════════════════════════════

# Base de datos (PostgreSQL en producción, SQLite local por defecto)
DATABASE_URL=sqlite:///./data/genia.db

# --- Proveedores de LLM ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# --- Vertex AI / GCP ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=
GCP_SERVICE_ACCOUNT_JSON=
VERTEX_GEMINI_MODEL=gemini-2.0-flash

# --- Orquestación de modelos ---
MODEL_TIMEOUT_S=30
MODEL_MAX_RETRIES=1
MODEL_FALLBACK_ORDER=vertex,groq,openrouter

# --- Meta WhatsApp Cloud API ---
META_ACCESS_TOKEN=
PHONE_NUMBER_ID=
WEBHOOK_VERIFY_TOKEN=genia_verify_token
META_APP_SECRET=

# --- Evolution API (WhatsApp alternativo) ---
EVOLUTION_API_URL=
EVOLUTION_API_TOKEN=

# --- WAHA (WhatsApp HTTP API, open-source, código QR) ---
# URL pública de tu servidor WAHA (donde corre el contenedor docker-compose.yml)
WAHA_API_URL=
# Api Key opcional: debe coincidir entre WAHA y la variable WAHA_API_KEY de Vercel
WAHA_API_KEY=

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma

# --- Seguridad / API multi-tenant ---
API_KEY_PEPPER=
ALLOWED_ORIGINS=
ENCRYPTION_KEY=

# --- Cobros Bre-B ---
BREB_LLAVE=
BREB_TITULAR=
SUBSCRIPTION_AMOUNT_COP=5000000

# --- MCP con-tranqui ---
CONTRANQUI_MCP_URL=
CONTRANQUI_MCP_SERVICE_TOKEN=

# --- Google Calendar OAuth 2.0 ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# --- Transcripción de voz (STT) ---
DEFAULT_STT_PROVIDER=groq_whisper
DEEPGRAM_API_KEY=
OPENAI_API_KEY=

# --- Text-to-Speech (TTS) ---
DEFAULT_TTS_PROVIDER=google_tts
ELEVENLABS_API_KEY=

# ═══════════════════════════════════════════════════════════════════════
# DASHBOARD (Next.js)
# ═══════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════
# VERCEL (automáticas, no tocar)
# ═══════════════════════════════════════════════════════════════════════
ENVIRONMENT=development
