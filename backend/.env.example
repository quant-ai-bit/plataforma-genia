# Base de datos
DATABASE_URL=sqlite:///./data/genia.db

# Groq (Chat LLM)
GROQ_API_KEY=gsk_your_key_here

# Google Gemini (Embeddings, Audio, Vision)
GEMINI_API_KEY=your_gemini_key_here

# Meta WhatsApp Cloud API (Fase 5)
META_ACCESS_TOKEN=
PHONE_NUMBER_ID=
WEBHOOK_VERIFY_TOKEN=genia_verify_token

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# ───────────────────────────────────────────────────────────────────────
# genia-agent-platform — variables de entorno (sin valores; rellenar en .env)
# ───────────────────────────────────────────────────────────────────────

# Vertex AI / GCP (proveedor de modelo primario: Gemini via Vertex AI)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_APPLICATION_CREDENTIALS=
# Contenido JSON del service account (alternativa al archivo anterior; ideal para Vercel)
GCP_SERVICE_ACCOUNT_JSON=
VERTEX_GEMINI_MODEL=

# Orquestacion de modelos (timeout / retry / orden de fallback)
MODEL_TIMEOUT_S=
MODEL_MAX_RETRIES=
MODEL_FALLBACK_ORDER=

# Cobros Bre-B (reemplaza Stripe; todas las claves solo desde el entorno)
# BREB_LLAVE: llave Bre-B del comercio destino de los cobros
# BREB_TITULAR: titular asociado a la llave (informativo)
# SUBSCRIPTION_AMOUNT_COP: monto mensual del cobro en centavos de COP (ej. 5000000 = $50.000)
BREB_LLAVE=
BREB_TITULAR=
SUBSCRIPTION_AMOUNT_COP=5000000

# Seguridad / API publica multi-tenant
API_KEY_PEPPER=
ALLOWED_ORIGINS=

# Cifrado de credenciales sensibles (WhatsApp por agente)
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# MCP remoto del tenant con-tranqui (conexion saliente GENIA -> con-tranqui)
CONTRANQUI_MCP_URL=
CONTRANQUI_MCP_SERVICE_TOKEN=
