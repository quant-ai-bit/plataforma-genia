# ═══ ENTORNO ═══
ENVIRONMENT=production

# ═══ BASE DE DATOS (SUPABASE POSTGRESQL) ═══
# URL de conexión a la base de datos (se recomienda usar el Pooler en puerto 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# ═══ SUPABASE CREDENCIALES (PARA AUTENTICACIÓN Y STORAGE) ═══
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-for-jwt-verification

# ═══ FRONTEND URL (PARA CORS) ═══
FRONTEND_URL=https://your-dashboard.vercel.app

# ═══ LLM PROVIDERS ═══
# Groq (Chat LLM principal)
GROQ_API_KEY=gsk_...
# Google Gemini (Embeddings, Audio, Vision)
GEMINI_API_KEY=AI...
# OpenRouter (Modelos adicionales como DeepSeek, Claude)
OPENROUTER_API_KEY=sk-or-...

# ═══ META WHATSAPP CLOUD API ═══
META_ACCESS_TOKEN=EAA...
PHONE_NUMBER_ID=123...
WEBHOOK_VERIFY_TOKEN=your_secure_verify_token
META_APP_SECRET=your_app_secret_for_webhook_signature_verification
